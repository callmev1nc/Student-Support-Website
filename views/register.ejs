<!DOCTYPE html>

<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register</title>
  <link rel="stylesheet" href="/stylesheets/register.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>
  <%- include("../templates/header", { headerTitle: "Registration" }) %>

  <div class="header">Western Sydney University</div>

  <div class="container">
    <div class="register-box">
      <h2>Welcome</h2>

      <% if (error) { %>
        <p class="error" style="color:red">
          <%= error %>
        </p>
      <% } %>

      <form id="registerForm" action="/register/home" method="POST">
        <input type="text" id="username" name="username" placeholder="Username" required>
        <input type="email" id="email" name="email" placeholder="Email" required>
        <input type="password" id="password" name="password" placeholder="Password" required>
        <!-- Hidden role: default to student -->
        <input type="hidden" name="roleName" value="student">

        <button type="submit" class="signup-btn">Sign Up</button>
        <small id="registerError" class="error"></small>
      </form>

      <p class="login-link">Already have an account? <a href="/login">Login here</a></p>
    </div>
  </div>

  <script>
    document.getElementById("registerForm").addEventListener("submit", function (event) {
      document.querySelectorAll(".error").forEach(el => el.textContent = "");
    });
  </script>
</body>

</html>
