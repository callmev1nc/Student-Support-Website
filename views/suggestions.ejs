<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include("header", { headerTitle: "Suggestions" }) %>

  <div class="page-banner">
    <div class="page-banner-inner">
      <h1>Suggestions for You</h1>
      <p>You logged a <%= mood %> mood — here are some tips</p>
    </div>
  </div>

  <div class="container">
    <ul class="tip-list">
      <% tips.forEach((tip, i) => { %>
        <li class="tip-card">
          <span class="tip-number"><%= i + 1 %></span>
          <span class="tip-text"><%= tip %></span>
        </li>
      <% }) %>
    </ul>

    <div class="mt-3 text-center">
      <a href="/mood/history" class="btn btn-secondary">View History</a>
      <a href="/mood" class="btn btn-primary" style="margin-left:0.5rem;">Log Another</a>
    </div>
  </div>

  <%- include("footer") %>
</body>
</html>
