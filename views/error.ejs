<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Error' %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>
  <%- include("header", { headerTitle: "Error" }) %>

  <div class="container text-center" style="padding-top:3rem;padding-bottom:3rem;">
    <h1 style="font-size:4rem;color:var(--wsu-red);">⚠️</h1>
    <h2><%= message || 'Something went wrong' %></h2>
    <p style="color:var(--color-text-muted);margin-top:0.5rem;">Oops! It looks like something went wrong.</p>

    <% if (error) { %>
      <div class="card mt-2" style="text-align:left;max-width:600px;margin:1rem auto;">
        <p><strong>Status:</strong> <%= error.status || 500 %></p>
        <% if (error.stack) { %>
          <pre style="background:var(--gray-100);padding:1rem;border-radius:var(--radius);font-size:0.8rem;overflow-x:auto;margin-top:0.5rem;"><%= error.stack %></pre>
        <% } %>
      </div>
    <% } %>

    <a href="/" class="btn btn-primary mt-2">Go Back Home</a>
  </div>

  <%- include("footer") %>
</body>

</html>
