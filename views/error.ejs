<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Error' %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include("header", { headerTitle: "Error" }) %>

  <div class="container text-center" style="padding-top:3rem;padding-bottom:3rem;">
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#BB1B36" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <h2 style="margin-top:1rem;"><%= message || 'Something went wrong' %></h2>
    <p style="color:var(--color-text-muted);">Oops! It looks like something went wrong.</p>

    <% if (error) { %>
      <div class="card mt-2" style="text-align:left;max-width:560px;margin:1rem auto;">
        <p style="margin:0;"><strong>Status:</strong> <%= error.status || 500 %></p>
        <% if (error.stack) { %>
          <pre style="background:var(--gray-100);padding:1rem;border-radius:var(--radius);font-size:0.75rem;overflow-x:auto;margin-top:0.75rem;"><%= error.stack %></pre>
        <% } %>
      </div>
    <% } %>

    <a href="/" class="btn btn-primary mt-2">Go Back Home</a>
  </div>

  <%- include("footer") %>
</body>
</html>
