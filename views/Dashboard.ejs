<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

  <!-- Header include -->
  <%- include("../templates/header", { headerTitle: "Dashboard" }) %>

    <main class="layout">

      <!-- Left sidebar: optional navigation -->
      <aside class="sidebar-left">
        <!-- Add any sidebar content or calendar here -->
      </aside>

      <!-- Centre content: Add/Search Events and Event Table -->
      <section class="centre">
        <h2>Welcome <%= user.username %>
        </h2>

        <fieldset>
          <legend>Add Event</legend>
          <form action="/events" method="POST">
            <input type="text" name="title" placeholder="Event Name" required />

            <label for="type">Type of Event:</label>
            <select name="type" id="type" required>
              <option value="">-- Select a type --</option>
              <option value="gaming">Gaming</option>
              <option value="study">Study</option>
              <option value="sport">Sport</option>
              <option value="religion">Religion</option>
              <option value="politics">Politics</option>
              <option value="other">Other</option>
            </select>

            <input type="date" name="date" required />
            <textarea name="description" placeholder="Description"></textarea>
            <button type="submit">Add Event</button>
          </form>
        </fieldset>

        <fieldset>
          <legend>Search Events</legend>
          <form action="/events/search" method="GET">
            <input type="text" name="query" placeholder="Search by name" />
            <button type="submit">Search</button>
          </form>
        </fieldset>

        <fieldset>
          <legend>All Events</legend>
          <% if (events && events.length> 0) { %>
            <table border="1" cellpadding="8" cellspacing="0">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Title</th>
                  <th>Description</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% events.forEach(event=> { %>
                  <tr>
                    <td>
                      <%= event.event_id %>
                    </td>
                    <td>
                      <%= event.event_title %>
                    </td>
                    <td>
                      <%= event.event_description %>
                    </td>
                    <td>
                      <%= new Date(event.event_date).toLocaleDateString() %>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
            <% } else { %>
              <p>No events found.</p>
              <% } %>
        </fieldset>

      </section>

      <!-- Right sidebar: optional content -->
      <aside class="sidebar-right">
        <!-- Add any extra info or calendar here -->
      </aside>

    </main>

    <footer>
      <%- include("../templates/footer") %>
    </footer>

    <style>
      .layout {
        display: grid;
        grid-template-columns: 200px 1fr 250px;
        gap: 20px;
        margin: 20px;
      }

      .centre {
        padding: 10px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      table th {
        background-color: #333;
        color: white;
        text-align: left;
      }

      table td {
        background-color: #f9f9f9;
        padding: 5px;
      }

      fieldset {
        margin-bottom: 20px;
        padding: 10px;
      }

      fieldset legend {
        font-weight: bold;
      }

      input,
      select,
      textarea,
      button {
        display: block;
        margin: 5px 0 10px 0;
        width: 100%;
        max-width: 400px;
        padding: 5px;
      }

      button {
        width: auto;
        padding: 8px 16px;
        background-color: #333;
        color: white;
        border: none;
        cursor: pointer;
      }

      button:hover {
        background-color: #555;
      }
    </style>

</body>

</html>