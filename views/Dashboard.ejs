<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/Dashboard.css">
</head>

<body>
  <%- include("header", { headerTitle: "Dashboard" }) %>

  <div class="page-banner">
    <h1>Welcome, <%= user.username %>!</h1>
    <p>Manage events and stay connected with campus</p>
  </div>

  <div class="dashboard-grid">

    <fieldset class="fieldset-card">
      <legend>Add Event</legend>
      <form action="/events" method="POST">
        <input type="text" name="title" placeholder="Event Name" required>
        <label for="type">Type of Event:</label>
        <select name="type" id="type" required>
          <option value="">-- Select a type --</option>
          <option value="gaming">Gaming</option>
          <option value="study">Study</option>
          <option value="sport">Sport</option>
          <option value="religion">Religion</option>
          <option value="politics">Politics</option>
          <option value="other">Other</option>
        </select>
        <input type="date" name="date" required>
        <textarea name="description" placeholder="Description"></textarea>
        <button type="submit" class="btn btn-primary" style="width:100%;">Add Event</button>
      </form>
    </fieldset>

    <fieldset class="fieldset-card">
      <legend>Search Events</legend>
      <form action="/events/search" method="GET">
        <input type="text" name="query" placeholder="Search by name">
        <button type="submit" class="btn btn-secondary" style="width:100%;">Search</button>
      </form>
    </fieldset>

    <section class="events-table-section">
      <fieldset class="fieldset-card">
        <legend>All Events</legend>
        <% if (events && events.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Type</th>
                <th>Description</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% events.forEach(event => { %>
                <tr>
                  <td><%= event.event_title %></td>
                  <td><%= event.event_type %></td>
                  <td><%= event.event_description %></td>
                  <td><%= new Date(event.event_date).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p style="color:var(--color-text-muted);text-align:center;padding:1rem;">No events found.</p>
        <% } %>
      </fieldset>
    </section>

  </div>

  <%- include("footer") %>
</body>

</html>
