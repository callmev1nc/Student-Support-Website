<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/Dashboard.css">
</head>
<body>
  <%- include("header", { headerTitle: "Dashboard" }) %>

  <div class="page-banner">
    <div class="page-banner-inner">
      <h1>Welcome, <%= user.username %></h1>
      <p>Manage events and stay connected with campus</p>
    </div>
  </div>

  <div class="dashboard-grid">

    <fieldset class="fieldset-card">
      <legend>Add Event</legend>
      <form action="/events" method="POST">
        <label for="title">Event Name</label>
        <input type="text" name="title" id="title" placeholder="Enter event name" required>
        <label for="type">Event Type</label>
        <select name="type" id="type" required>
          <option value="">-- Select type --</option>
          <option value="gaming">Gaming</option>
          <option value="study">Study</option>
          <option value="sport">Sport</option>
          <option value="religion">Religion</option>
          <option value="politics">Politics</option>
          <option value="other">Other</option>
        </select>
        <label for="date">Date</label>
        <input type="date" name="date" id="date" required>
        <label for="description">Description</label>
        <textarea name="description" id="description" placeholder="Brief description of the event" rows="3"></textarea>
        <button type="submit" class="btn btn-primary" style="width:100%;">Add Event</button>
      </form>
    </fieldset>

    <fieldset class="fieldset-card">
      <legend>Search Events</legend>
      <form action="/events/search" method="GET">
        <label for="query">Search by name</label>
        <input type="text" name="query" id="query" placeholder="Search events...">
        <button type="submit" class="btn btn-secondary" style="width:100%;margin-top:0.5rem;">Search</button>
      </form>
    </fieldset>

    <section class="events-table-section">
      <fieldset class="fieldset-card">
        <legend>All Events</legend>
        <% if (events && events.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Type</th>
                <th>Description</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% events.forEach(event => { %>
                <tr>
                  <td><strong><%= event.event_title %></strong></td>
                  <td><%= event.event_type %></td>
                  <td><%= event.event_description %></td>
                  <td><%= new Date(event.event_date).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p style="color:var(--color-text-muted);text-align:center;padding:2rem 0;">No events found.</p>
        <% } %>
      </fieldset>
    </section>

  </div>

  <%- include("footer") %>
</body>
</html>
