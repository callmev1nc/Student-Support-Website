<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mood History</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <%- include("header", { headerTitle: "Mood History" }) %>

  <div class="page-banner">
    <div class="page-banner-inner">
      <h1>Your Mood History</h1>
      <p>Track your emotional wellbeing over time</p>
    </div>
  </div>

  <div class="container">
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-value"><%= totalMoods %></div>
        <div class="stat-label">Total Entries</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:#16A34A"><%= positiveMoods %></div>
        <div class="stat-label">Positive</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:var(--wsu-red)"><%= negativeMoods %></div>
        <div class="stat-label">Negative</div>
      </div>
    </div>

    <% if (moods.length === 0) { %>
      <div class="card text-center" style="padding:2.5rem;">
        <p style="margin:0;color:var(--color-text-muted);">No moods logged yet. <a href="/mood">Log your first mood</a></p>
      </div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Mood</th>
            <th>Type</th>
            <th>Notes</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% moods.forEach(mood => { %>
            <tr>
              <td><strong><%= mood.mood %></strong></td>
              <td><%= mood.mood_type %></td>
              <td><%= mood.notes %></td>
              <td><%= new Date(mood.date).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <%- include("footer") %>
</body>
</html>
