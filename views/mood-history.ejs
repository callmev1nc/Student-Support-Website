<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

  <!-- Include header, using headerTitle passed from controller -->
  <%- include("header", { headerTitle: headerTitle }) %>

    <fieldset>
      <h1>Welcome <%= user ? user.username : "Guest" %>! — Your Mood History</h1>
    </fieldset>

    <h2>Previously Entered Moods</h2>

    <main class="layout">

      <!-- Left sidebar for calendar and navigation -->
      <aside class="sidebar-left">
        <!-- optional navigation / calendar -->
      </aside>

      <!-- Centre content: list of previous moods -->
      <section class="centre">
        <table border="1" cellpadding="10" cellspacing="0">
          <p>So far you have entered <%= totalMoods %> moods:</p>

          <% if (moods.length===0) { %>
            <p>No moods logged yet.</p>
            <% } else { %>
              <tr>
                <th>Mood</th>
                <th>Mood Type</th>
                <th>Additional Notes</th>
                <th>Date</th>
              </tr>
              <% moods.forEach(mood=> { %>
                <tr>
                  <td>
                    <%= mood.mood %>
                  </td>
                  <td>
                    <%= mood.mood_type %>
                  </td>
                  <td>
                    <%= mood.notes %>
                  </td>
                  <td>
                    <%= new Date(mood.date).toLocaleString() %>
                  </td>
                </tr>
                <% }) %>
                  <% } %>
        </table>
      </section>

    </main>

    <footer>
      <%- include("footer") %>
    </footer>

    <style>
      .layout {
        display: grid;
        grid-template-columns: 200px 1fr 250px;
        gap: 20px;
        margin: 20px;
      }

      .centre {
        padding: 10px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      table th {
        background-color: #333;
        color: white;
      }

      table td {
        background-color: #f9f9f9;
      }
    </style>

</body>

</html>