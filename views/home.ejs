<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
  <link rel='stylesheet' href='/stylesheets/style.css'>
  <link rel="stylesheet" href="/stylesheets/home.css">
</head>
<body>
  <%- include("header", { headerTitle: title }) %>

  <section class="landing-hero">
    <span class="hero-badge">Western Sydney University</span>
    <h1>CampusWell</h1>
    <p class="hero-subtitle">Your student mental wellbeing platform</p>
    <p>Track your mood, discover campus events, and access support resources — all in one place.</p>
    <div class="landing-buttons">
      <a href="/login" class="btn btn-primary">Sign In</a>
      <a href="/register" class="btn btn-secondary">Create Account</a>
    </div>

    <div class="features-row">
      <div class="feature-item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#BB1B36" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        <span>Mood Tracking</span>
      </div>
      <div class="feature-item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#BB1B36" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span>Campus Events</span>
      </div>
      <div class="feature-item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#BB1B36" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span>Wellbeing Support</span>
      </div>
    </div>
  </section>

  <%- include("footer") %>
</body>
</html>
