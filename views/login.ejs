<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/login.css">
</head>
<body>
  <%- include("header", { headerTitle: "Login" }) %>

  <div class="login-wrapper">
    <div class="login-card">
      <h2>Sign In</h2>
      <p class="login-sub">Welcome back to CampusWell</p>
      <form id="loginForm" action="/login/Dashboard" method="POST">
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <label for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="Enter your username" required>
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter your password" required>
        <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;">Sign In</button>
        <p class="login-link">Don't have an account? <a href="/register">Create one</a></p>
      </form>
    </div>
  </div>

  <%- include("footer") %>
</body>
</html>
