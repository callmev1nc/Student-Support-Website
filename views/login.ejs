<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/login.css">
</head>

<body>
  <%- include("header", { headerTitle: "Login" }) %>

  <div class="login-wrapper">
    <div class="login-card">
      <form id="loginForm" action="/login/Dashboard" method="POST">
        <h2>Welcome Back</h2>
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <input type="text" name="username" placeholder="Username" required>
        <input type="password" name="password" placeholder="Password" required>
        <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;">Login</button>
        <p class="login-link">Don't have an account? <a href="/register">Register here</a></p>
      </form>
    </div>
  </div>

  <%- include("footer") %>
</body>

</html>
