<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register Admin</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/register.css">
</head>
<body>
  <%- include("header", { headerTitle: "Register Admin" }) %>

  <div class="page-banner">
    <div class="page-banner-inner">
      <h1>Register Admin</h1>
      <p>Create an administrator account</p>
    </div>
  </div>

  <div class="register-wrapper">
    <div class="register-card">
      <h2>New Admin</h2>
      <p class="uni-name">Western Sydney University</p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form action="/register-admin" method="POST">
        <label for="username">Admin Username</label>
        <input type="text" name="username" id="username" placeholder="Enter admin username" required>
        <label for="password">Password</label>
        <input type="password" name="password" id="password" placeholder="Create a password" required>
        <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;">Register Admin</button>
      </form>
      <p class="login-link"><a href="/events">Back to Dashboard</a></p>
    </div>
  </div>

  <%- include("footer") %>
</body>
</html>
