<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register Admin</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link rel="stylesheet" href="/stylesheets/register.css">
</head>

<body>
  <%- include("header", { headerTitle: "Register Admin" }) %>

  <div class="page-banner">
    <h1>Register New Admin</h1>
    <p>Create an administrator account</p>
  </div>

  <div class="register-wrapper">
    <div class="register-card">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form action="/register-admin" method="POST">
        <input type="text" name="username" placeholder="Admin Username" required>
        <input type="password" name="password" placeholder="Password" required>
        <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;">Register Admin</button>
      </form>
      <p class="login-link"><a href="/events">Back to Dashboard</a></p>
    </div>
  </div>

  <%- include("footer") %>
</body>

</html>
