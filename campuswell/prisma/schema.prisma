generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  STAFF
  ADMIN
}

enum TicketCategory {
  ACADEMIC
  MENTAL_HEALTH
  TECHNICAL
  BULLYING
  ATTENDANCE
  FINANCIAL
  GENERAL
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  NEW
  IN_REVIEW
  ASSIGNED
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum NotificationType {
  TICKET
  APPOINTMENT
  MESSAGE
  ANNOUNCEMENT
  FORUM
  GROUP
  MENTORSHIP
  QUESTION
  ASSISTANT
}

enum StudyTaskCategory {
  HOMEWORK
  ASSIGNMENT
  QUIZ
  EXAM_PREP
  READING
  PROJECT
  OTHER
}

enum StudyTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum FocusMode {
  POMODORO
  SHORT_BREAK
  LONG_BREAK
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  avatarUrl    String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tickets           Ticket[]
  assignedTickets   Ticket[]        @relation("AssignedTickets")
  comments          Comment[]
  appointments      Appointment[]   @relation("StudentAppointments")
  staffAppointments Appointment[]   @relation("StaffAppointments")
  conversationsA    Conversation[]  @relation("ParticipantA")
  conversationsB    Conversation[]  @relation("ParticipantB")
  sentMessages      Message[]
  notifications     Notification[]
  authoredAnnouncements Announcement[]
  authoredResources     Resource[]
  moodEntries           MoodEntry[]
  courses               Course[]
  grades                Grade[]
  studyTasks            StudyTask[]
  focusSessions         FocusSession[]
  journalEntries        JournalEntry[]

  @@map("users")
}

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  description String
  category    TicketCategory @default(GENERAL)
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(NEW)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  studentId    String
  student      User    @relation(fields: [studentId], references: [id])
  assignedToId String?
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [id])

  comments    Comment[]
  attachments Attachment[]

  @@map("tickets")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  ticketId String
  ticket   Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User    @relation(fields: [authorId], references: [id])

  @@map("comments")
}

model Attachment {
  id        String   @id @default(cuid())
  url       String
  filename  String
  createdAt DateTime @default(now())

  ticketId String
  ticket   Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Appointment {
  id               String             @id @default(cuid())
  title            String
  description      String?
  status           AppointmentStatus  @default(PENDING)
  scheduledAt      DateTime
  durationMinutes  Int                @default(30)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  studentId String
  student   User  @relation("StudentAppointments", fields: [studentId], references: [id])

  staffId String
  staff   User    @relation("StaffAppointments", fields: [staffId], references: [id])

  @@map("appointments")
}

model Conversation {
  id            String    @id @default(cuid())
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())

  participantAId String
  participantA   User  @relation("ParticipantA", fields: [participantAId], references: [id])

  participantBId String
  participantB   User  @relation("ParticipantB", fields: [participantBId], references: [id])

  messages Message[]

  @@unique([participantAId, participantBId])
  @@map("conversations")
}

model Message {
  id             String    @id @default(cuid())
  content        String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User    @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  authorId String
  author   User     @relation(fields: [authorId], references: [id])

  @@map("announcements")
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  url         String
  type        String   @default("LINK")
  createdAt   DateTime @default(now())

  authorId String
  author   User     @relation(fields: [authorId], references: [id])

  @@map("resources")
}

// One mood check-in per user per day (UTC). dayKey is midnight UTC and carries
// the @@unique pair so the action can upsert today's entry cleanly.
model MoodEntry {
  id        String   @id @default(cuid())
  score     Int
  note      String?
  dayKey    DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([userId, createdAt])
  @@map("mood_entries")
}

model Course {
  id        String   @id @default(cuid())
  code      String
  name      String
  credits   Int      @default(10)
  term      String?
  color     String?
  archived  Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grades    Grade[]
  tasks     StudyTask[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("courses")
}

model Grade {
  id        String   @id @default(cuid())
  name      String
  score     Decimal  @db.Decimal(5,2)
  maxScore  Decimal  @db.Decimal(5,2) @default(100)
  weight    Decimal? @db.Decimal(5,2)
  gradedAt  DateTime?
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@map("grades")
}

model StudyTask {
  id            String            @id @default(cuid())
  title         String
  description   String?
  category      StudyTaskCategory @default(HOMEWORK)
  priority      TicketPriority    @default(MEDIUM)
  status        StudyTaskStatus   @default(TODO)
  dueAt         DateTime?
  completedAt   DateTime?
  reminderAt    DateTime?
  courseId      String?
  course        Course?           @relation(fields: [courseId], references: [id])
  focusSessions FocusSession[]   @relation("TaskFocusSessions")
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  @@index([userId, status])
  @@index([userId, dueAt])
  @@map("study_tasks")
}

model FocusSession {
  id              String     @id @default(cuid())
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  mode            FocusMode  @default(POMODORO)
  completed       Boolean    @default(false)
  taskId          String?
  task            StudyTask? @relation("TaskFocusSessions", fields: [taskId], references: [id])
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  @@index([userId, startedAt])
  @@map("focus_sessions")
}

// Private journal. {title, content} is encrypted as one AES-256-GCM blob
// (payload + per-record iv + authTag) via src/lib/journal-crypto.ts, because
// Supabase is DB-only with no RLS. A missing JOURNAL_ENCRYPTION_KEY fails
// lazily (only when the journal is used) so the rest of the app stays up.
model JournalEntry {
  id        String   @id @default(cuid())
  payload   String
  iv        String
  authTag   String
  mood      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@map("journal_entries")
}
