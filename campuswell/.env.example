# Copy to .env (local dev) and set the same keys in Vercel Project Environment Variables.

# Supabase connection pooler (IPv4, transaction mode) — REQUIRED at runtime.
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# Direct connection (IPv6). Only needed for `prisma migrate`, NOT at runtime.
DIRECT_URL=postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# NextAuth — REQUIRED. Generate with: openssl rand -base64 32
AUTH_SECRET=

# NextAuth canonical URL in production (e.g. https://campuswell.vercel.app).
# Optional on Vercel (auto-detected) but recommended to avoid redirect issues.
AUTH_URL=

# Private journal at-rest encryption — 32-byte base64 key (AES-256-GCM).
# REQUIRED in production for the journal (generate with: openssl rand -base64 32).
# Optional in dev (a deterministic dev key is used when unset). Rotating the key
# requires a re-encrypt migration of existing journal_entries rows.
JOURNAL_ENCRYPTION_KEY=

# Groq free tier (no credit card). Key: https://console.groq.com/keys
GROQ_API_KEY=
ASSISTANT_MODEL=llama-3.3-70b-versatile
ASSISTANT_HOURLY_CAP=20
ASSISTANT_DAILY_CAP=80
